{
  "name": "tomorrow-night-burns",
  "displayName": "Tomorrow Night Burns",
  "description": "Dark crimson VS Code theme ported from the iTerm2 'Tomorrow Night Burns' scheme.",
  "version": "0.0.1",
  "publisher": "str3sss",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/str3sss/tomorrow-night-burns.git"
  },
  "bugs": {
    "url": "https://github.com/str3sss/tomorrow-night-burns/issues"
  },
  "homepage": "https://github.com/str3sss/tomorrow-night-burns#readme",
  "scripts": {
    "package": "pnpm dlx @vscode/vsce package",
    "install:local": "pnpm dlx @vscode/vsce package -o tomorrow-night-burns.vsix && code --install-extension tomorrow-night-burns.vsix --force",
    "publish:vsce": "pnpm dlx @vscode/vsce publish",
    "publish:ovsx": "pnpm dlx ovsx publish"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "tomorrow",
    "red",
    "crimson"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Tomorrow Night Burns",
        "uiTheme": "vs-dark",
        "path": "./themes/tomorrow-night-burns-color-theme.json"
      }
    ]
  }
}
